    "    \"End\":     {t: df[\"Date\"].max().date() for t, df in all_data.items()},\n",
    "    \"Fund_NaN\":{t: df[\"Gross_Margin\"].isna().sum() if \"Gross_Margin\" in df.columns else \"N/A\"\n",
