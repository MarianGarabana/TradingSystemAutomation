   "id": "00000013",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "[standard] Ridge alpha CV (TimeSeriesSplit n=5, metric=direction_accuracy):\n",
      "  α=  0.01  |  CV dir acc = 0.5179\n",
      "  α=  0.10  |  CV dir acc = 0.5180\n",
      "  α=  1.00  |  CV dir acc = 0.5176\n",
