      "v2+ features         (11):  ['MA5', 'MA20', 'Volume_Change', 'Market_Cap', 'RSI', 'MACD', 'Log_Return', 'Volatility_20', 'Return_norm', 'Return_norm_Lag1', 'Return_norm_Lag2']\n",
      "Fallback tickers: ['BAC', 'GS', 'JPM', 'MA', 'V']\n"
